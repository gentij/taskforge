server {
  listen 80;
  server_name lune.example.com;
  return 301 https://$host$request_uri;
}

server {
  listen 443 ssl http2;
  server_name lune.example.com;

  ssl_certificate /etc/letsencrypt/live/lune.example.com/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/lune.example.com/privkey.pem;

  client_max_body_size 1m;

  # Public webhook ingress only.
  location /v1/api/hooks/ {
    proxy_pass http://127.0.0.1:3000;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  # Keep admin API private by default.
  location /v1/api/ {
    return 403;
  }
}
